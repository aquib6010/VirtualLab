# ─── Server ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/virtual-lab?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY=7d

# ─── CORS ─────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
